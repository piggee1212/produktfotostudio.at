---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

let allArticles: any[] = [];
try {
  allArticles = await getCollection('ratgeber');
} catch (e) {
  allArticles = [];
}

const latestArticles = allArticles
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 6);

const features = [
  {
    title: 'Ratgeber',
    description: 'Umfassende Anleitungen für jede Art von Produktfotografie — von Mode über Schmuck bis hin zu Lebensmitteln.',
    href: '/ratgeber/',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />`
  },
  {
    title: 'Kosten-Guide',
    description: 'Transparente Preisübersicht für professionelle Produktfotografie in Wien und ganz Österreich.',
    href: '/kosten/',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />`
  },
  {
    title: 'FAQ',
    description: 'Antworten auf die häufigsten Fragen rund um Produktfotografie, Ablauf und technische Anforderungen.',
    href: '/faq/',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />`
  },
];

const stats = [
  { value: '150+', label: 'Kampagnen' },
  { value: '5.000+', label: 'Produkte fotografiert' },
  { value: '100%', label: 'Fokus auf Conversion' },
  { value: '10+', label: 'Jahre Erfahrung' },
];

const categoryMap: Record<string, string> = {
  'produkt-typ': 'Produkttypen',
  'technik': 'Fototechniken',
  'beleuchtung': 'Beleuchtung',
  'plattform': 'Plattformen',
  'business': 'Business & ROI',
  'post-produktion': 'Post-Produktion',
  'lokal': 'Lokal & Regional',
  'vergleich': 'Vergleiche',
  'checklisten': 'Checklisten',
  'trends': 'Trends & Zukunft',
};
---

<BaseLayout
  title="Startseite"
  description="Ihr umfassender Ratgeber für professionelle Produktfotografie in Österreich. Tipps, Kosten, Techniken und Anleitungen vom Experten."
  keywords={['Produktfotografie', 'Wien', 'Österreich', 'E-Commerce', 'Produktfotos', 'Ratgeber']}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-900 via-navy-950 to-navy-950"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-amber-500/5 rounded-full blur-3xl"></div>
    <div class="absolute top-20 right-0 w-96 h-96 bg-amber-500/3 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 rounded-full bg-amber-500/10 border border-amber-500/20 px-4 py-1.5 text-sm text-amber-400 font-medium mb-8 animate-fade-in">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
          </svg>
          Ihr Wissensportal für Produktfotografie
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white font-heading leading-tight mb-6 animate-slide-up">
          Professionelle
          <span class="text-gradient"> Produktfotografie</span>
          <br />in Österreich
        </h1>

        <p class="text-lg sm:text-xl text-navy-300 max-w-2xl mx-auto mb-10 leading-relaxed animate-slide-up" style="animation-delay: 0.1s;">
          Ratgeber, Tipps und Preisübersichten für E-Commerce-Unternehmen, die mit hochwertigen Produktbildern mehr verkaufen möchten.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.2s;">
          <a href="/ratgeber/" class="inline-flex items-center gap-2 rounded-xl bg-amber-500 px-6 py-3.5 text-base font-semibold text-navy-950 transition-all hover:bg-amber-400 hover:shadow-lg hover:shadow-amber-500/20 hover:-translate-y-0.5">
            Ratgeber entdecken
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="/kosten/" class="inline-flex items-center gap-2 rounded-xl border border-navy-600 bg-navy-800/50 px-6 py-3.5 text-base font-medium text-navy-200 transition-all hover:bg-navy-800 hover:border-navy-500 hover:text-white">
            Kosten erfahren
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="relative border-y border-navy-800 bg-navy-900/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-extrabold text-gradient font-heading">{stat.value}</div>
            <div class="mt-1 text-sm text-navy-400">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature Cards -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white font-heading mb-4">Alles über Produktfotografie</h2>
      <p class="text-navy-400 max-w-2xl mx-auto">Von der richtigen Beleuchtung bis zu den Kosten — unser Wissensportal deckt alle Aspekte professioneller Produktfotografie ab.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {features.map((feature) => (
        <a href={feature.href} class="group card-hover rounded-2xl border border-navy-700 bg-navy-800/30 p-8 block">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 border border-amber-500/20 mb-5 transition-colors group-hover:bg-amber-500/20">
            <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={feature.icon} />
          </div>
          <h3 class="text-xl font-bold text-white font-heading mb-2 group-hover:text-amber-400 transition-colors">{feature.title}</h3>
          <p class="text-sm text-navy-400 leading-relaxed">{feature.description}</p>
          <div class="mt-4 flex items-center gap-1 text-sm text-amber-500 font-medium">
            Mehr erfahren
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Latest Articles -->
  {latestArticles.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-3xl font-bold text-white font-heading mb-2">Neueste Ratgeber</h2>
          <p class="text-navy-400">Frische Artikel und Anleitungen</p>
        </div>
        <a href="/ratgeber/" class="hidden sm:inline-flex items-center gap-2 text-sm text-amber-500 font-medium hover:text-amber-400 transition-colors">
          Alle anzeigen
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {latestArticles.map((article) => (
          <a href={`/ratgeber/${article.id}/`} class="group card-hover rounded-xl border border-navy-700 bg-navy-800/30 p-6 block">
            <span class="badge badge-amber mb-3">{categoryMap[article.data.category] || article.data.category}</span>
            <h3 class="text-lg font-semibold text-white font-heading group-hover:text-amber-400 transition-colors mb-2">{article.data.title}</h3>
            <p class="text-sm text-navy-400 line-clamp-2 mb-4">{article.data.description}</p>
            <div class="flex items-center gap-1 text-xs text-amber-500 font-medium">
              Weiterlesen
              <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="relative overflow-hidden border-t border-navy-800 bg-navy-900/50">
    <div class="absolute inset-0 bg-gradient-to-r from-amber-500/5 via-transparent to-amber-500/5"></div>
    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white font-heading mb-4">
        Professionelle Produktfotografie buchen?
      </h2>
      <p class="text-lg text-navy-300 mb-8 max-w-2xl mx-auto">
        Vladimir Kocian bietet maßgeschneiderte Premium-Produktfotografie für E-Commerce, Fashion und Marken in Wien und ganz Österreich. Bis zu 5.000 Produkte pro Projekt mit höchster Qualität.
      </p>
      <a
        href="https://www.vladimirkocian.com/de/contact/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-amber-500 px-8 py-4 text-base font-semibold text-navy-950 transition-all hover:bg-amber-400 hover:shadow-lg hover:shadow-amber-500/20 hover:-translate-y-0.5"
      >
        Unverbindliches Angebot anfordern
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>
      <p class="mt-4 text-sm text-navy-500">
        Besuchen Sie <a href="https://www.vladimirkocian.com" target="_blank" rel="noopener noreferrer" class="text-amber-500/70 hover:text-amber-400 underline underline-offset-2">vladimirkocian.com</a> für Portfolio und Referenzen.
      </p>
    </div>
  </section>
</BaseLayout>
