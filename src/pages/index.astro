---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

let allArticles: any[] = [];
try {
  allArticles = await getCollection('ratgeber');
} catch (e) {
  allArticles = [];
}

const latestArticles = allArticles
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 6);

const features = [
  {
    title: 'Ratgeber',
    description: 'Umfassende Anleitungen für jede Art von Produktfotografie — von Mode über Schmuck bis hin zu Lebensmitteln.',
    href: '/ratgeber/',
    icon: 'menu_book',
  },
  {
    title: 'Kosten-Guide',
    description: 'Transparente Preisübersicht für professionelle Produktfotografie in Wien und ganz Österreich.',
    href: '/kosten/',
    icon: 'euro',
  },
  {
    title: 'FAQ',
    description: 'Antworten auf die häufigsten Fragen rund um Produktfotografie, Ablauf und technische Anforderungen.',
    href: '/faq/',
    icon: 'help',
  },
];

const stats = [
  { value: '150+', label: 'Kampagnen' },
  { value: '5.000+', label: 'Produkte fotografiert' },
  { value: '100%', label: 'Fokus auf Conversion' },
  { value: '10+', label: 'Jahre Erfahrung' },
];

const categoryMap: Record<string, string> = {
  'produkt-typ': 'Produkttypen',
  'technik': 'Fototechniken',
  'beleuchtung': 'Beleuchtung',
  'plattform': 'Plattformen',
  'business': 'Business & ROI',
  'post-produktion': 'Post-Produktion',
  'lokal': 'Lokal & Regional',
  'vergleich': 'Vergleiche',
  'checklisten': 'Checklisten',
  'trends': 'Trends & Zukunft',
};

const heroImages = [
  {
    src: 'https://lh3.googleusercontent.com/aida/AP1WRLs5peJwigAslL1g8dYePgoyVN8E7e0KB4iQpK3GpuB5aXX_mtnNM9KZEm_WoRdu2cV7PPtXR0uY14mBlGlWxagpZEjFf2wRQUlDhSdgmWBBSZ0GgmhayaZj1kYHn46Ct1lYQfk9ek-k6mcF-cjxCG6IIQesYsWxUdHiYiC0fYyxwS8zVGMjKqc81-LuyYZep8b82IPMAD0_ZPu5kr-9sKLmIsu79ZhxTnCwaI8ZjPQCDW2_HYLZtmo6jMxp',
    alt: 'Produktfotografie Beispiel 1',
    classes: 'absolute top-4 right-8 w-44 h-56 rotate-[-6deg] z-30',
  },
  {
    src: 'https://lh3.googleusercontent.com/aida/AP1WRLuCkMVlj64YnjNH4cvYfI1zNHpmfO-gB8YN-xO_bgWclxMQTFZcv8k3lLNzbAKBvE1ZhYIe5HfxEd9k1d0Qg7_xHHTiN-BGmq5b8NZD52acrIayR9qRruhisyzjJRP8YMjEz2nZttxqFHwGt_t24ZsSQ8r8oQNmJP6prIamLh05Wfa68HSkfY65E07M_nPIgUvA5O4NfD-eJOrdwO1VJXEu--UfemE5QjZW1Yim2MQGZl_MRyXquGMFk1yy',
    alt: 'Produktfotografie Beispiel 2',
    classes: 'absolute top-20 right-40 w-40 h-52 rotate-[4deg] z-20',
  },
  {
    src: 'https://lh3.googleusercontent.com/aida/AP1WRLtbl6wON9pvLk9Kb-bHtENs1Zc_khH--RTdHAm1zMrgUonW7tVGVrhoZClvaoQAgPjruoiydkNuiCyHxoX4Dl_yKf7G8JxYdej9kmCUSjQqYh9qrodMw40IKHtXkMaVogRqlcupp8JVnrbWffyE4qqD5FMpRmvw6LX9fUSaHm77Q-uQfi7JXNmuZKVBnuQD8QwsVzR6VleLLPVOzQ3TfkY5nauByBvndguDeAFIsJFDs6065Hv4WMN43Lnh',
    alt: 'Produktfotografie Beispiel 3',
    classes: 'absolute top-44 right-16 w-36 h-48 rotate-[8deg] z-10',
  },
  {
    src: 'https://lh3.googleusercontent.com/aida/AP1WRLvToHGpeVDTk94sP6JC5lhGqEo8QjMyb4uMPcHvFs_jkQjl6YS91pm2LDdzu5kHgLFQCw8PbYC2cn2_2gmvzSl8UhPFMEd9fuhvMJrw-dsDvplpGjbYSfuHK2rMOUjHOkldX4Op28xi8zqMhMnlwMBBE11kCXFdXuiQIt1S-TfHgJcScrC8seMDeLD1fXUjVqqLEEk4_rUWLmbBxac1OmnzRFvGmnP_GRcugKl9pTxVJnX711PVTh7bhJW2',
    alt: 'Produktfotografie Beispiel 4',
    classes: 'absolute top-8 right-56 w-32 h-44 rotate-[-3deg] z-40',
  },
  {
    src: 'https://lh3.googleusercontent.com/aida/AP1WRLvJnADL3C3UEm1mZs7CV8YlopMGbc9yh0aOy1QgbNMoxIkykvZ092SH__7Y_IlQ1afC4ha-OW-w5SMWOgZFKgSyAqo9gmBSapsnHPpt96jOcoQPV2N7IHmkLIAv2Swb5ivsuHJRXx5wo9i_cmIighofcDkNHItfcMCsk0v8I9fItOdPTrFRyA3ZKeG0_1XeQfZe38UdFiA6h0hoW-l4B9rDm87gR00hgn_HxrwUiG0QVcIaRMBHUjrzpswA',
    alt: 'Produktfotografie Beispiel 5',
    classes: 'absolute top-52 right-44 w-36 h-44 rotate-[-10deg] z-5',
  },
];
---

<BaseLayout
  title="Startseite"
  description="Ihr umfassender Ratgeber für professionelle Produktfotografie in Österreich. Tipps, Kosten, Techniken und Anleitungen vom Experten."
  keywords={['Produktfotografie', 'Wien', 'Österreich', 'E-Commerce', 'Produktfotos', 'Ratgeber']}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background gradients -->
    <div class="absolute inset-0 bg-gradient-to-b from-navy-900 via-navy-950 to-navy-950"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-[#ffb4aa]/5 rounded-full blur-3xl"></div>
    <div class="absolute top-20 right-0 w-96 h-96 bg-[#ffb4aa]/3 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
        <!-- Left column: Text -->
        <div class="max-w-xl">
          <!-- Badge pill -->
          <div class="inline-flex items-center gap-2 rounded-full bg-white/5 border border-white/10 px-4 py-1.5 text-sm text-[#ffb4aa] font-medium mb-8 backdrop-blur-sm animate-fade-in">
            <span class="material-symbols-outlined text-[18px]">auto_awesome</span>
            Ihr Wissensportal für Produktfotografie
          </div>

          <!-- H1 -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white font-heading leading-tight mb-6 animate-slide-up">
            Professionelle
            <span class="bg-gradient-to-r from-[#ffb4aa] to-[#c8c6c5] bg-clip-text text-transparent">Produktfotografie</span>
          </h1>

          <!-- Subtitle -->
          <p class="text-lg sm:text-xl text-navy-300 mb-10 leading-relaxed animate-slide-up" style="animation-delay: 0.1s;">
            Ratgeber, Tipps und Preisübersichten für E-Commerce-Unternehmen.
          </p>

          <!-- CTA buttons -->
          <div class="flex flex-col sm:flex-row items-start gap-4 animate-slide-up" style="animation-delay: 0.2s;">
            <a href="/ratgeber/" class="inline-flex items-center gap-2 rounded-xl bg-[#ffb4aa] px-6 py-3.5 text-base font-semibold text-navy-950 transition-all hover:bg-[#ffc8c1] hover:shadow-lg hover:shadow-[#ffb4aa]/20 hover:-translate-y-0.5">
              Ratgeber entdecken
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </a>
            <a href="/kosten/" class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 backdrop-blur-sm px-6 py-3.5 text-base font-medium text-navy-200 transition-all hover:bg-white/10 hover:border-white/25 hover:text-white">
              Kosten erfahren
            </a>
          </div>
        </div>

        <!-- Right column: Floating product images -->
        <div class="relative hidden lg:block h-[420px]">
          {heroImages.map((img) => (
            <img
              src={img.src}
              alt={img.alt}
              loading="eager"
              class:list={[
                img.classes,
                'rounded-2xl shadow-2xl border border-white/20 object-cover transition-transform duration-500 hover:scale-105',
              ]}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="relative border-y border-white/10 bg-white/5 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
        {stats.map((stat, i) => (
          <div class:list={[
            'text-center',
            i < 3 ? 'lg:border-r lg:border-white/10' : '',
          ]}>
            <div class="text-3xl sm:text-4xl font-extrabold bg-gradient-to-r from-[#ffb4aa] to-[#c8c6c5] bg-clip-text text-transparent font-heading">{stat.value}</div>
            <div class="mt-1 text-xs text-navy-400 uppercase tracking-widest font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Overview Section (3 cards) -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white font-heading mb-4">Alles über Produktfotografie</h2>
      <p class="text-navy-400 max-w-2xl mx-auto">Von der richtigen Beleuchtung bis zu den Kosten — unser Wissensportal deckt alle Aspekte professioneller Produktfotografie ab.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {features.map((feature) => (
        <a href={feature.href} class="group bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 block transition-all duration-300 hover:-translate-y-1 hover:bg-white/8 hover:border-white/20 hover:shadow-xl hover:shadow-black/20">
          <!-- Icon circle -->
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-[#ffb4aa]/10 border border-[#ffb4aa]/20 mb-6 transition-colors group-hover:bg-[#ffb4aa]/20">
            <span class="material-symbols-outlined text-[28px] text-[#ffb4aa]">{feature.icon}</span>
          </div>
          <h3 class="text-xl font-bold text-white font-heading mb-3 group-hover:text-[#ffb4aa] transition-colors">{feature.title}</h3>
          <p class="text-sm text-navy-400 leading-relaxed mb-5">{feature.description}</p>
          <div class="flex items-center gap-1.5 text-sm text-[#ffb4aa] font-medium">
            Mehr erfahren
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Latest Articles -->
  {latestArticles.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-3xl font-bold text-white font-heading mb-2">Neueste Ratgeber</h2>
          <p class="text-navy-400">Frische Artikel und Anleitungen</p>
        </div>
        <a href="/ratgeber/" class="hidden sm:inline-flex items-center gap-2 text-sm text-[#ffb4aa] font-medium hover:text-[#ffc8c1] transition-colors">
          Alle anzeigen
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {latestArticles.map((article) => (
          <a href={`/ratgeber/${article.id}/`} class="group bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 block transition-all duration-300 hover:-translate-y-1 hover:bg-white/8 hover:border-white/20 hover:shadow-xl hover:shadow-black/20">
            <span class="inline-flex items-center rounded-full bg-[#ffb4aa]/10 border border-[#ffb4aa]/20 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-[#ffb4aa] mb-4">{categoryMap[article.data.category] || article.data.category}</span>
            <h3 class="text-lg font-semibold text-white font-heading group-hover:text-[#ffb4aa] transition-colors mb-2">{article.data.title}</h3>
            <p class="text-sm text-navy-400 line-clamp-2 mb-5">{article.data.description}</p>
            <div class="flex items-center gap-1 text-xs text-[#ffb4aa] font-medium">
              Weiterlesen
              <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="relative overflow-hidden border-t border-white/10 bg-white/3">
    <div class="absolute inset-0 bg-gradient-to-r from-[#ffb4aa]/5 via-transparent to-[#ffb4aa]/5"></div>
    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white font-heading mb-4">
        Professionelle Produktfotografie buchen?
      </h2>
      <p class="text-lg text-navy-300 mb-8 max-w-2xl mx-auto">
        Vladimir Kocian bietet maßgeschneiderte Premium-Produktfotografie für E-Commerce, Fashion und Marken in Wien und ganz Österreich. Bis zu 5.000 Produkte pro Projekt mit höchster Qualität.
      </p>
      <a
        href="https://www.vladimirkocian.com/de/contact/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-[#ffb4aa] px-8 py-4 text-base font-semibold text-navy-950 transition-all hover:bg-[#ffc8c1] hover:shadow-lg hover:shadow-[#ffb4aa]/20 hover:-translate-y-0.5"
      >
        Unverbindliches Angebot anfordern
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>
      <p class="mt-4 text-sm text-navy-500">
        Besuchen Sie <a href="https://www.vladimirkocian.com" target="_blank" rel="noopener noreferrer" class="text-[#ffb4aa]/70 hover:text-[#ffb4aa] underline underline-offset-2">vladimirkocian.com</a> für Portfolio und Referenzen.
      </p>
    </div>
  </section>
</BaseLayout>
