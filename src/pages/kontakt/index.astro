---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontakt" description="Kontaktieren Sie das Produktfoto Studio Wien für Fragen zu Produktfotografie, Angebote und Beratung." keywords={['Kontakt Produktfotografie Wien', 'Produktfoto Studio Kontakt']}>

  <section class="relative overflow-hidden bg-navy-900 border-b border-navy-800">
    <div class="absolute inset-0 bg-gradient-to-br from-amber-500/5 via-transparent to-transparent"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
      <span class="badge badge-amber mb-4">Kontakt</span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white font-heading leading-tight mb-4">Sprechen Sie mit uns</h1>
      <p class="text-lg text-navy-300 max-w-2xl">Haben Sie Fragen zur Produktfotografie oder möchten ein unverbindliches Angebot? Wir freuen uns auf Ihre Nachricht.</p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid gap-8 md:grid-cols-2">
      <div class="rounded-2xl border border-navy-700 bg-navy-800/30 p-8">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 border border-amber-500/20 mb-5">
          <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
        </div>
        <h2 class="text-xl font-bold text-white font-heading mb-2">E-Mail</h2>
        <a href="mailto:kocian@vladimirkocian.com" class="text-amber-400 hover:text-amber-300 text-lg transition-colors">kocian@vladimirkocian.com</a>
        <p class="text-sm text-navy-400 mt-2">Wir antworten in der Regel innerhalb von 24 Stunden.</p>
      </div>

      <div class="rounded-2xl border border-navy-700 bg-navy-800/30 p-8">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 border border-amber-500/20 mb-5">
          <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
        </div>
        <h2 class="text-xl font-bold text-white font-heading mb-2">Telefon</h2>
        <a href="tel:+4366473411300" class="text-amber-400 hover:text-amber-300 text-lg transition-colors">+43 664 73 411300</a>
        <p class="text-sm text-navy-400 mt-2">Mo–Fr, 9:00–18:00 Uhr</p>
      </div>
    </div>

    <div class="mt-8 rounded-2xl border border-navy-700 bg-navy-800/30 p-8 text-center">
      <h2 class="text-xl font-bold text-white font-heading mb-2">Website & Portfolio</h2>
      <p class="text-navy-300 mb-4">Besuchen Sie die Hauptwebsite für Portfolio, Referenzen und direkte Buchung:</p>
      <a href="https://www.vladimirkocian.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 text-lg font-medium transition-colors">
        www.vladimirkocian.com
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
  </div>
</BaseLayout>
