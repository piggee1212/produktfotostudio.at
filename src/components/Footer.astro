---
const currentYear = new Date().getFullYear();

const footerLinks = {
  ratgeber: [
    { href: '/ratgeber/', label: 'Alle Ratgeber' },
    { href: '/kosten/', label: 'Kosten & Preise' },
    { href: '/faq/', label: 'FAQ' },
  ],
  unternehmen: [
    { href: '/ueber-uns/', label: 'Über uns' },
    { href: '/kontakt/', label: 'Kontakt' },
  ],
  rechtliches: [
    { href: '/impressum/', label: 'Impressum' },
    { href: '/datenschutz/', label: 'Datenschutz' },
  ],
};

const socialLinks = [
  {
    href: 'https://www.linkedin.com/in/vladimir-kocian-b5208310/',
    label: 'LinkedIn',
    icon: `<path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    href: 'https://www.instagram.com/vladimirkocian/',
    label: 'Instagram',
    icon: `<path fill="currentColor" d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 1 0 0-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 1 1-2.882 0 1.441 1.441 0 0 1 2.882 0z"/>`,
  },
];
---

<footer class="border-t border-navy-800 bg-navy-950">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand Column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 group">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-amber-500/10 border border-amber-500/20">
            <svg class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-bold tracking-wider text-amber-500 font-heading uppercase leading-tight">Produktfoto</span>
            <span class="text-[0.65rem] font-medium tracking-[0.2em] text-navy-400 uppercase leading-tight">Studio Wien</span>
          </div>
        </a>
        <p class="mt-4 text-sm text-navy-400 leading-relaxed max-w-xs">
          Ihr Wissenszentrum für professionelle Produktfotografie in Österreich. Tipps, Ratgeber und Preisinfos.
        </p>
        <div class="mt-6 flex gap-3">
          {socialLinks.map((social) => (
            <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label}
              class="flex h-9 w-9 items-center justify-center rounded-lg bg-navy-800 text-navy-400 transition-all hover:bg-amber-500/10 hover:text-amber-500 border border-navy-700 hover:border-amber-500/30">
              <svg class="h-4 w-4" viewBox="0 0 24 24" set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Ratgeber -->
      <div>
        <h3 class="text-sm font-semibold text-white font-heading uppercase tracking-wider mb-4">Ratgeber</h3>
        <ul class="space-y-2.5">
          {footerLinks.ratgeber.map((link) => (
            <li><a href={link.href} class="text-sm text-navy-400 hover:text-amber-400 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Unternehmen -->
      <div>
        <h3 class="text-sm font-semibold text-white font-heading uppercase tracking-wider mb-4">Unternehmen</h3>
        <ul class="space-y-2.5">
          {footerLinks.unternehmen.map((link) => (
            <li><a href={link.href} class="text-sm text-navy-400 hover:text-amber-400 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Rechtliches -->
      <div>
        <h3 class="text-sm font-semibold text-white font-heading uppercase tracking-wider mb-4">Rechtliches</h3>
        <ul class="space-y-2.5">
          {footerLinks.rechtliches.map((link) => (
            <li><a href={link.href} class="text-sm text-navy-400 hover:text-amber-400 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-navy-800">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-xs text-navy-500">&copy; {currentYear} Produktfoto Studio Wien. Alle Rechte vorbehalten.</p>
        <p class="text-xs text-navy-500">
          Ein Projekt von{' '}
          <a href="https://www.vladimirkocian.com" target="_blank" rel="noopener noreferrer" class="text-amber-500/70 hover:text-amber-400 transition-colors">Vladimir Kocian</a>
        </p>
      </div>
    </div>
  </div>
</footer>
