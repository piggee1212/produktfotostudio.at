---
const currentYear = new Date().getFullYear();

const footerLinks = {
  ratgeber: [
    { href: '/ratgeber/', label: 'Alle Ratgeber' },
    { href: '/kosten/', label: 'Kosten & Preise' },
    { href: '/faq/', label: 'FAQ' },
  ],
  unternehmen: [
    { href: '/ueber-uns/', label: 'Über uns' },
    { href: '/kontakt/', label: 'Kontakt' },
  ],
  rechtliches: [
    { href: '/impressum/', label: 'Impressum' },
    { href: '/datenschutz/', label: 'Datenschutz' },
  ],
};
---

<footer class="bg-white/5 backdrop-blur-md border-t border-white/10">
  <div class="mx-auto max-w-[1280px] px-4 md:px-6 py-12 lg:py-16">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand Column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 group">
          <div class="w-8 h-8 rounded bg-white/10 flex items-center justify-center border border-white/20 group-hover:border-[#ffb4aa]/50 transition-colors">
            <span class="material-symbols-outlined text-[#ffb4aa] text-xl" style="font-variation-settings: 'FILL' 1;">camera_alt</span>
          </div>
          <div class="flex flex-col">
            <span class="text-[12px] tracking-[0.1em] font-bold text-[#ffb4aa] leading-tight">PRODUKTFOTO</span>
            <span class="text-[8px] tracking-widest text-[#e9bcb6] leading-tight font-bold">STUDIO WIEN</span>
          </div>
        </a>
        <p class="mt-4 text-sm text-[#e9bcb6] leading-relaxed max-w-xs">
          Ihr Wissenszentrum für professionelle Produktfotografie in Österreich. Tipps, Ratgeber und Preisinfos.
        </p>
        <div class="mt-6 flex gap-3">
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/in/vladimir-kocian-b5208310/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
            class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-[#e9bcb6] transition-all hover:bg-white/10 hover:text-[#ffb4aa] border border-white/10 hover:border-[#ffb4aa]/30">
            <svg class="h-4 w-4" viewBox="0 0 24 24">
              <path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="https://www.instagram.com/vladimirkocian/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
            class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-[#e9bcb6] transition-all hover:bg-white/10 hover:text-[#ffb4aa] border border-white/10 hover:border-[#ffb4aa]/30">
            <svg class="h-4 w-4" viewBox="0 0 24 24">
              <path fill="currentColor" d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 1 0 0-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 1 1-2.882 0 1.441 1.441 0 0 1 2.882 0z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Ratgeber -->
      <div>
        <h3 class="text-[12px] tracking-[0.1em] font-bold text-[#ffdad5] uppercase mb-4">Ratgeber</h3>
        <ul class="space-y-2.5">
          {footerLinks.ratgeber.map((link) => (
            <li><a href={link.href} class="text-sm text-[#e9bcb6] hover:text-[#c8c6c5] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Unternehmen -->
      <div>
        <h3 class="text-[12px] tracking-[0.1em] font-bold text-[#ffdad5] uppercase mb-4">Unternehmen</h3>
        <ul class="space-y-2.5">
          {footerLinks.unternehmen.map((link) => (
            <li><a href={link.href} class="text-sm text-[#e9bcb6] hover:text-[#c8c6c5] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Rechtliches -->
      <div>
        <h3 class="text-[12px] tracking-[0.1em] font-bold text-[#ffdad5] uppercase mb-4">Rechtliches</h3>
        <ul class="space-y-2.5">
          {footerLinks.rechtliches.map((link) => (
            <li><a href={link.href} class="text-sm text-[#e9bcb6] hover:text-[#c8c6c5] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="mx-auto max-w-[1280px] px-4 md:px-6 py-6">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-xs text-[#e9bcb6]/60">&copy; {currentYear} Produktfoto Studio Wien. Alle Rechte vorbehalten.</p>
        <p class="text-xs text-[#e9bcb6]/60">
          Ein Projekt von{' '}
          <a href="https://www.vladimirkocian.com" target="_blank" rel="noopener noreferrer" class="text-[#ffb4aa]/70 hover:text-[#ffb4aa] transition-colors">Vladimir Kocian</a>
        </p>
      </div>
    </div>
  </div>
</footer>
