---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  ogImage?: string;
  schemaType?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  keywords = [],
  ogImage = '/images/og-default.jpg',
  schemaType,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://produktfotostudio.at');
const fullTitle = title === 'Startseite'
  ? 'Produktfoto Studio Wien – Ihr Ratgeber für Produktfotografie in Österreich'
  : `${title} | Produktfoto Studio Wien`;

const baseSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Produktfoto Studio Wien',
  url: 'https://produktfotostudio.at',
  description: 'Professionelle Produktfotografie in Wien, Österreich. Ratgeber, Tipps und Preisübersicht.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Wien',
    addressCountry: 'AT',
  },
  founder: {
    '@type': 'Person',
    name: 'Vladimir Kocian',
    url: 'https://www.vladimirkocian.com',
  },
  sameAs: [
    'https://www.vladimirkocian.com',
    'https://www.linkedin.com/in/vladimir-kocian-b5208310/',
    'https://www.instagram.com/vladimirkocian/',
  ],
  image: ogImage,
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Produktfoto Studio Wien',
  url: 'https://produktfotostudio.at',
  inLanguage: 'de-AT',
  publisher: {
    '@type': 'Organization',
    name: 'Produktfoto Studio Wien',
    url: 'https://produktfotostudio.at',
  },
};
---

<!doctype html>
<html lang="de" class="antialiased">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H9EPFJEZ24"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-H9EPFJEZ24');
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta name="author" content="Vladimir Kocian" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

    <link rel="canonical" href={canonicalURL.href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={new URL(ogImage, Astro.site || 'https://produktfotostudio.at').href} />
    <meta property="og:site_name" content="Produktfoto Studio Wien" />
    <meta property="og:locale" content="de_AT" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site || 'https://produktfotostudio.at').href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>
  <body class="min-h-screen flex flex-col antialiased bg-background text-on-surface">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
